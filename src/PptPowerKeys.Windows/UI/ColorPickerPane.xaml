<UserControl x:Class="PptPowerKeys.Windows.UI.ColorPickerPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="240">
  <ScrollViewer x:Name="RootScroller" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="4">
      <TextBlock Text="Smart Color Picker"
                 FontWeight="SemiBold"
                 FontSize="14"
                 Margin="0,0,0,8" />

      <TextBlock x:Name="FallbackWarning"
                 Text="Theme colors unavailable — using default palette."
                 Foreground="DarkOrange"
                 TextWrapping="Wrap"
                 Margin="0,0,0,8"
                 Visibility="Collapsed" />

      <TextBlock Text="Theme colors" FontWeight="SemiBold" Margin="0,0,0,4" />
      <UniformGrid x:Name="ThemeSwatches" Columns="5" Margin="0,0,0,8" />

      <StackPanel x:Name="RecentSection" Visibility="Collapsed" Margin="0,0,0,8">
        <TextBlock Text="Recent" FontWeight="SemiBold" Margin="0,0,0,4" />
        <UniformGrid x:Name="RecentSwatches" Columns="5" />
      </StackPanel>

      <TextBlock Text="Custom HEX" FontWeight="SemiBold" Margin="0,0,0,4" />
      <Grid Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="HexInput"
                 Grid.Column="0"
                 Margin="0,0,6,0"
                 ToolTip="#RRGGBB"
                 KeyDown="OnHexInputKeyDown" />
        <Button Grid.Column="1"
                Content="Set"
                Padding="8,2"
                Click="OnHexSetClick" />
      </Grid>
      <TextBlock x:Name="HexError"
                 Foreground="Red"
                 TextWrapping="Wrap"
                 Margin="0,0,0,8"
                 Visibility="Collapsed" />

      <TextBlock Text="Pick from shape" FontWeight="SemiBold" Margin="0,0,0,4" />
      <WrapPanel Margin="0,0,0,8">
        <Button Content="Fill"
                Margin="0,0,6,6"
                Padding="8,2"
                Click="OnPickFillClick" />
        <Button Content="Line"
                Margin="0,0,6,6"
                Padding="8,2"
                Click="OnPickLineClick" />
        <Button Content="Text"
                Margin="0,0,6,6"
                Padding="8,2"
                Click="OnPickTextClick" />
      </WrapPanel>

      <StackPanel x:Name="PreviewPanel" Orientation="Horizontal" Margin="0,0,0,8" Visibility="Collapsed">
        <Border x:Name="PreviewSwatch"
                Width="24"
                Height="24"
                Margin="0,0,8,0"
                BorderBrush="Gray"
                BorderThickness="1" />
        <TextBlock x:Name="PreviewHex" VerticalAlignment="Center" />
      </StackPanel>

      <WrapPanel>
        <Button x:Name="ApplyFillButton"
                Content="Apply Fill"
                Margin="0,0,8,8"
                Padding="10,4"
                Click="OnApplyFillClick" />
        <Button x:Name="ApplyLineButton"
                Content="Apply Line"
                Margin="0,0,8,8"
                Padding="10,4"
                Click="OnApplyLineClick" />
        <Button x:Name="ApplyTextButton"
                Content="Apply Text"
                Margin="0,0,8,8"
                Padding="10,4"
                Click="OnApplyTextClick" />
      </WrapPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
