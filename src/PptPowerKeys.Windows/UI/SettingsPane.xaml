<UserControl x:Class="PptPowerKeys.Windows.UI.SettingsPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="280">
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Settings"
               FontSize="16"
               FontWeight="SemiBold"
               Margin="0,0,0,8" />

    <TabControl x:Name="MainTabs" Grid.Row="1">
      <TabItem Header="General">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <TextBlock x:Name="PresetWarning"
                       Text="Applying preset replaces current shortcuts. Click Save to persist."
                       TextWrapping="Wrap"
                       Foreground="DarkOrange"
                       Margin="0,0,0,8"
                       Visibility="Collapsed" />
            <TextBlock x:Name="ImportWarning"
                       TextWrapping="Wrap"
                       Foreground="DarkOrange"
                       Margin="0,0,0,8"
                       Visibility="Collapsed" />

            <TextBlock Text="Profile" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ComboBox x:Name="ProfileCombo"
                      Margin="0,0,0,12"
                      SelectionChanged="OnProfileSelectionChanged" />

            <CheckBox x:Name="SnapToGridCheck"
                      Content="Snap to grid (0.1 cm)"
                      Margin="0,0,0,12" />

            <TextBlock Text="Object statistics display" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ComboBox x:Name="AddupModeCombo"
                      Margin="0,0,0,12"
                      SelectionChanged="OnAddupModeSelectionChanged" />

            <TextBlock x:Name="ShortcutsHeader"
                       Text="Shortcuts"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <DataGrid x:Name="ShortcutsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      MaxHeight="220"
                      Margin="0,0,0,8">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Command"
                                    Binding="{Binding CommandTitle}"
                                    IsReadOnly="True"
                                    Width="*" />
                <DataGridTextColumn Header="Keys"
                                    Binding="{Binding Keys, UpdateSourceTrigger=PropertyChanged}"
                                    Width="100" />
                <DataGridTemplateColumn Header="" Width="36">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Button Content="×"
                              Padding="4,0"
                              Click="OnDeleteShortcutClick"
                              Tag="{Binding}" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>

            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <ComboBox x:Name="NewCommandCombo"
                        Grid.Column="0"
                        Margin="0,0,4,0"
                        DisplayMemberPath="Title" />
              <TextBox x:Name="NewKeysBox"
                       Grid.Column="1"
                       Margin="0,0,4,0"
                       ToolTip="e.g. Alt+1" />
              <Button Grid.Column="2"
                      Content="Add"
                      Padding="8,2"
                      Click="OnAddShortcutClick" />
            </Grid>

            <WrapPanel Margin="0,4,0,0">
              <Button Content="Save"
                      Margin="0,0,8,8"
                      Padding="12,4"
                      Click="OnSaveClick" />
              <Button Content="Reset to defaults"
                      Margin="0,0,8,8"
                      Padding="12,4"
                      Click="OnResetClick" />
              <Button Content="Export JSON"
                      Margin="0,0,8,8"
                      Padding="12,4"
                      Click="OnExportClick" />
              <Button Content="Import JSON"
                      Margin="0,0,8,8"
                      Padding="12,4"
                      Click="OnImportClick" />
            </WrapPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem x:Name="ColorsTab" Header="Colors">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16">
          <TextBlock Text="Color picker — S10-005"
                     FontSize="14"
                     TextAlignment="Center"
                     TextWrapping="Wrap" />
          <TextBlock Text="Full theme color picker will be implemented in S10-005."
                     Margin="0,8,0,0"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     Foreground="Gray" />
        </StackPanel>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>
