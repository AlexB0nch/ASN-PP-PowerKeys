<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="OnLoad">
  <ribbon>
    <tabs>
      <tab id="tabPowerKeys" label="PowerKeys" insertAfterMso="TabHome">
        <group id="grpLayout" label="Layout">
          <button id="btnAlignLeft"
                  label="Align Left"
                  onAction="OnAlignLeft"
                  size="large"
                  imageMso="ObjectsAlignLeft"
                  screentip="Align Left"
                  supertip="Align selected shapes to the left edge of the anchor (last selected shape). Core in-process, no HTTP." />
        </group>
        <group id="grpBootstrap" label="Bootstrap">
          <button id="btnBootstrap"
                  label="Test"
                  onAction="OnBootstrapAction"
                  size="normal"
                  imageMso="HappyFace"
                  screentip="PptPowerKeys.Windows bootstrap"
                  supertip="Confirms the VSTO add-in and shared Core catalog are loaded." />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
