<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="OnLoad">
  <ribbon>
    <tabs>
      <tab id="tabPowerKeys" label="PowerKeys" insertAfterMso="TabHome">
        <group id="grpAlignment" label="Alignment">
          <button id="btnAlignLeft"
                  label="Left"
                  onAction="OnLayoutCommand"
                  size="large"
                  imageMso="ObjectsAlignLeft"
                  screentip="Align Left"
                  supertip="Align selected shapes to the left edge of the anchor (last selected shape)." />
          <button id="btnAlignCenterHorizontal"
                  label="Center"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsAlignCenterHorizontal"
                  screentip="Align Center Horizontal" />
          <button id="btnAlignRight"
                  label="Right"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsAlignRight"
                  screentip="Align Right" />
          <button id="btnAlignTop"
                  label="Top"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsAlignTop"
                  screentip="Align Top" />
          <button id="btnAlignMiddleVertical"
                  label="Middle"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsAlignMiddleVertical"
                  screentip="Align Middle Vertical" />
          <button id="btnAlignBottom"
                  label="Bottom"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsAlignBottom"
                  screentip="Align Bottom" />
          <button id="btnDistributeHorizontal"
                  label="Dist H"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsDistributeHorizontally"
                  screentip="Distribute Horizontal" />
          <button id="btnDistributeVertical"
                  label="Dist V"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsDistributeVertically"
                  screentip="Distribute Vertical" />
        </group>
        <group id="grpStack" label="Stack">
          <button id="btnAlignLeftToRight"
                  label="To Right"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectBringForward"
                  screentip="Place to Right of Anchor"
                  supertip="Position each shape so its left edge meets the anchor's right edge." />
          <button id="btnAlignRightToLeft"
                  label="To Left"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectSendBackward"
                  screentip="Place to Left of Anchor" />
          <button id="btnAlignTopToBottom"
                  label="Below"
                  onAction="OnLayoutCommand"
                  imageMso="AlignBottom"
                  screentip="Place Below Anchor" />
          <button id="btnAlignBottomToTop"
                  label="Above"
                  onAction="OnLayoutCommand"
                  imageMso="AlignTop"
                  screentip="Place Above Anchor" />
        </group>
        <group id="grpPosition" label="Position">
          <button id="btnCopyObjectPosition"
                  label="Copy Position"
                  onAction="OnHostScriptCommand"
                  size="large"
                  imageMso="Copy"
                  screentip="Copy object position"
                  supertip="Save the anchor (last selected) shape Left/Top to the in-memory clipboard." />
          <button id="btnPasteObjectPosition"
                  label="Paste Position"
                  onAction="OnHostScriptCommand"
                  imageMso="Paste"
                  screentip="Paste object position"
                  supertip="Apply the copied Left/Top to all selected shapes (width and height unchanged)." />
        </group>
        <group id="grpSize" label="Size">
          <button id="btnSameWidth"
                  label="Same Width"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsSameWidth"
                  screentip="Same Width" />
          <button id="btnSameHeight"
                  label="Same Height"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsSameHeight"
                  screentip="Same Height" />
          <button id="btnSameWidthKeepAspect"
                  label="W + Aspect"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsSameWidth"
                  screentip="Same Width (Keep Aspect)" />
          <button id="btnSameHeightKeepAspect"
                  label="H + Aspect"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsSameHeight"
                  screentip="Same Height (Keep Aspect)" />
          <button id="btnWidthEqualsAnchorHeight"
                  label="W = Anchor H"
                  onAction="OnLayoutCommand"
                  imageMso="ShapeRectangle"
                  screentip="Width = Anchor Height" />
          <button id="btnHeightEqualsAnchorWidth"
                  label="H = Anchor W"
                  onAction="OnLayoutCommand"
                  imageMso="ShapeRectangle"
                  screentip="Height = Anchor Width" />
        </group>
        <group id="grpStretch" label="Stretch">
          <button id="btnStretchWidthToLeft"
                  label="To Left"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsAlignLeft"
                  screentip="Stretch Width to Anchor Left" />
          <button id="btnStretchWidthToRight"
                  label="To Right"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsAlignRight"
                  screentip="Stretch Width to Anchor Right" />
          <button id="btnStretchHeightToTop"
                  label="To Top"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsAlignTop"
                  screentip="Stretch Height to Anchor Top" />
          <button id="btnStretchHeightToBottom"
                  label="To Bottom"
                  onAction="OnLayoutCommand"
                  imageMso="ObjectsAlignBottom"
                  screentip="Stretch Height to Anchor Bottom" />
        </group>
        <group id="grpNudgeLarge" label="Nudge Large">
          <button id="btnIncreaseWidthLarge"
                  label="+ Width"
                  onAction="OnLayoutCommand"
                  imageMso="IncreaseIndent"
                  screentip="Increase Width (Large)" />
          <button id="btnDecreaseWidthLarge"
                  label="- Width"
                  onAction="OnLayoutCommand"
                  imageMso="DecreaseIndent"
                  screentip="Decrease Width (Large)" />
          <button id="btnIncreaseHeightLarge"
                  label="+ Height"
                  onAction="OnLayoutCommand"
                  imageMso="IncreaseIndent"
                  screentip="Increase Height (Large)" />
          <button id="btnDecreaseHeightLarge"
                  label="- Height"
                  onAction="OnLayoutCommand"
                  imageMso="DecreaseIndent"
                  screentip="Decrease Height (Large)" />
          <button id="btnIncreaseSizeKeepAspect"
                  label="+ Size"
                  onAction="OnLayoutCommand"
                  imageMso="ZoomIn"
                  screentip="Increase Size (Keep Aspect)" />
          <button id="btnDecreaseSizeKeepAspect"
                  label="- Size"
                  onAction="OnLayoutCommand"
                  imageMso="ZoomOut"
                  screentip="Decrease Size (Keep Aspect)" />
        </group>
        <group id="grpNudgeSmall" label="Nudge Small">
          <button id="btnIncreaseWidthSmall"
                  label="+ W"
                  onAction="OnLayoutCommand"
                  imageMso="HappyFace"
                  screentip="Increase Width (Small)" />
          <button id="btnDecreaseWidthSmall"
                  label="- W"
                  onAction="OnLayoutCommand"
                  imageMso="HappyFace"
                  screentip="Decrease Width (Small)" />
          <button id="btnIncreaseHeightSmall"
                  label="+ H"
                  onAction="OnLayoutCommand"
                  imageMso="HappyFace"
                  screentip="Increase Height (Small)" />
          <button id="btnDecreaseHeightSmall"
                  label="- H"
                  onAction="OnLayoutCommand"
                  imageMso="HappyFace"
                  screentip="Decrease Height (Small)" />
        </group>
        <group id="grpObjects" label="Objects">
          <button id="btnInsertRectangle"
                  label="Rectangle"
                  onAction="OnHostScriptCommand"
                  size="large"
                  imageMso="ShapeRectangle"
                  screentip="Insert rectangle"
                  supertip="Insert a rectangle near the top-left of the active slide (100,100 — 150×100 pt)." />
          <button id="btnInsertSquare"
                  label="Square"
                  onAction="OnHostScriptCommand"
                  imageMso="ShapeRectangle"
                  screentip="Insert square"
                  supertip="Insert a square near the top-left of the active slide (100×100 pt)." />
          <button id="btnInsertEllipse"
                  label="Ellipse"
                  onAction="OnHostScriptCommand"
                  imageMso="ShapeOval"
                  screentip="Insert ellipse"
                  supertip="Insert an ellipse near the top-left of the active slide (100,100 — 150×100 pt)." />
          <button id="btnInsertLine"
                  label="Line"
                  onAction="OnHostScriptCommand"
                  imageMso="ShapeStraightLine"
                  screentip="Insert line"
                  supertip="Insert a horizontal line near the top-left of the active slide." />
          <button id="btnInsertTextbox"
                  label="Textbox"
                  onAction="OnHostScriptCommand"
                  imageMso="TextBoxInsert"
                  screentip="Insert text box"
                  supertip="Insert an empty text box near the top-left of the active slide (100,100 — 200×80 pt)." />
          <button id="btnInsertArrow"
                  label="Arrow"
                  onAction="OnHostScriptCommand"
                  imageMso="ShapeRightArrow"
                  screentip="Insert arrow"
                  supertip="Insert a horizontal line with a triangle end arrowhead (COM full parity)." />
        </group>
        <group id="grpCopyAndAlign" label="Copy &amp; Align">
          <button id="btnCopyAndAlignLeft"
                  label="Copy + Left"
                  onAction="OnHostScriptCommand"
                  size="large"
                  imageMso="ObjectsAlignLeft"
                  screentip="Duplicate + Align Left"
                  supertip="Duplicate each selected shape at its position, then align clones to the anchor (last selected)." />
          <button id="btnCopyAndAlignRight"
                  label="Copy + Right"
                  onAction="OnHostScriptCommand"
                  imageMso="ObjectsAlignRight"
                  screentip="Duplicate + Align Right" />
          <button id="btnCopyAndAlignTop"
                  label="Copy + Top"
                  onAction="OnHostScriptCommand"
                  imageMso="ObjectsAlignTop"
                  screentip="Duplicate + Align Top" />
          <button id="btnCopyAndAlignBottom"
                  label="Copy + Bottom"
                  onAction="OnHostScriptCommand"
                  imageMso="ObjectsAlignBottom"
                  screentip="Duplicate + Align Bottom" />
        </group>
        <group id="grpOptions" label="Options">
          <checkBox id="chkSnapToGrid"
                    label="Snap to grid (0.1 cm)"
                    getPressed="GetSnapToGridPressed"
                    onAction="OnSnapToGridToggle"
                    screentip="Snap to grid"
                    supertip="When enabled, layout commands snap geometry to a 0.1 cm grid (Consulting Mode)." />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
